DEPLOY_BASE=/opt/capics
SERVICE_USER=capics
JAVA_BIN=/usr/bin/java
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=capics
DB_URL=jdbc:postgresql://${DB_HOST}:${DB_PORT}/${DB_NAME}
DB_USERNAME=capics_user
DB_PASSWORD=CHANGE_ME_CAPICS_DB_PASSWORD
DB_SCHEMA_MODE=incremental
# DB_SCHEMA_MODE options:
#   incremental : production default, only run deploy/sql/migrations/*.sql once each
#   bootstrap   : run schema.sql only when DB has no tables
#   reset       : force run schema.sql (drops/recreates tables)

POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=CHANGE_ME_POSTGRES_ADMIN_PASSWORD

JWT_SECRET=CHANGE_ME_TO_A_RANDOM_32_PLUS_CHAR_SECRET
JWT_EXPIRATION=86400000
APP_CORS_ALLOWED_ORIGINS=https://capics.example.com
LOG_LEVEL_APP=INFO
LOG_LEVEL_SECURITY=WARN

NGINX_SERVER_NAME=capics.example.com
NGINX_WEB_ROOT=/usr/share/nginx/html/capics
NGINX_CONF_PATH=/etc/nginx/conf.d/capics.conf
ENABLE_HTTPS=true
SSL_CERT_PATH=/etc/letsencrypt/live/${NGINX_SERVER_NAME}/fullchain.pem
SSL_CERT_KEY_PATH=/etc/letsencrypt/live/${NGINX_SERVER_NAME}/privkey.pem
BASE_URL=https://${NGINX_SERVER_NAME}
